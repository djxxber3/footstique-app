<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="8dp"
    style="@style/Widget.Footstique.CardView">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/img_team_home"
            android:layout_width="50dp"
            android:layout_height="50dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/txt_score"
            app:layout_constraintHorizontal_chainStyle="spread_inside"
            tools:src="@android:drawable/ic_menu_gallery"
            android:contentDescription="@string/home_team_logo" />

        <TextView
            android:id="@+id/txt_team_home"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="@color/fs_white"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/img_team_home"
            app:layout_constraintStart_toStartOf="@id/img_team_home"
            app:layout_constraintEnd_toEndOf="@id/img_team_home"
            tools:text="Team A" />

        <TextView
            android:id="@+id/txt_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/fs_orange"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/img_team_home"
            app:layout_constraintBottom_toBottomOf="@id/img_team_home"
            app:layout_constraintStart_toEndOf="@id/img_team_home"
            app:layout_constraintEnd_toStartOf="@id/img_team_away"
            tools:text="2 - 1" />

        <TextView
            android:id="@+id/txt_match_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/fs_light_grey"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/txt_score"
            app:layout_constraintStart_toStartOf="@id/txt_score"
            app:layout_constraintEnd_toEndOf="@id/txt_score"
            tools:text="Live" />

        <ImageView
            android:id="@+id/img_team_away"
            android:layout_width="50dp"
            android:layout_height="50dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/txt_score"
            app:layout_constraintEnd_toEndOf="parent"
            tools:src="@android:drawable/ic_menu_gallery"
            android:contentDescription="@string/away_team_logo" />

        <TextView
            android:id="@+id/txt_team_away"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="@color/fs_white"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/img_team_away"
            app:layout_constraintStart_toStartOf="@id/img_team_away"
            app:layout_constraintEnd_toEndOf="@id/img_team_away"
            tools:text="Team B" />

        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="@color/fs_grey_divider"
            app:layout_constraintTop_toBottomOf="@id/txt_team_home"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/txt_league_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@color/fs_light_grey"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:text="Premier League" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>