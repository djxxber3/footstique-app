<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.Footstique.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/fs_dark_grey_secondary</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <style name="Widget.Footstique.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/fs_orange</item>
        <item name="android:textColor">@color/fs_white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Footstique.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/fs_dark_grey_primary</item>
        <item name="titleTextColor">@color/fs_white</item>
    </style>

</resources>